  cron          String?   @db.VarChar(100)
  timezone      String    @default("Asia/Kolkata") @db.VarChar(50)
  retentionDays Int       @default(30) @map("retention_days")
  backupType    String    @default("full") @map("backup_type") @db.VarChar(20) // full, incremental
  nextRun       DateTime? @map("next_run") @db.Timestamptz()
  lastRun       DateTime? @map("last_run") @db.Timestamptz()
  updatedBy     String?   @map("updated_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, companyId])
  @@map("backup_schedules")
}
