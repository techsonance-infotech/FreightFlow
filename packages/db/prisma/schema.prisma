// ============================================
// FreightFlow — Prisma Schema
// Multi-Tenant SaaS Transport Management
// ============================================

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// PLATFORM-LEVEL TABLES (Super Admin)
// ============================================

model Tenant {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(255)
  slug             String    @unique @db.VarChar(100)
  plan             String    @default("starter") @db.VarChar(50)
  status           String    @default("active") @db.VarChar(20)
  kycStatus        String    @default("pending") @map("kyc_status") @db.VarChar(20)
  licenseKey       String?   @map("license_key") @db.Text
  licenseExpiresAt DateTime? @map("license_expires_at") @db.Timestamptz()
  settings         Json?     @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  companies       Company[]
  users           User[]
  modules         TenantModule[]
  licenseKeys     LicenseKey[]
  licenseRequests LicenseRequest[]
  usageRecords    TenantUsage[]
  kycDocuments    KycDocument[]
  invoices        PlatformInvoice[]
  apiKeys         PlatformApiKey[]
  webhooks        WebhookConfig[]
  supportTickets  SupportTicket[]

  // ... (rest of the relations)

  dealers              Dealer[]
  consignors           Consignor[]
  consignees           Consignee[]
  vehicles             Vehicle[]
  labours              Labour[]
  productCategories    ProductCategory[]
  productUnits         ProductUnit[]
  products             Product[]
  employees            Employee[]
  orders               Order[]
  pallets              OrderPallet[]
  trips                Trip[]
  tripExpenses         TripExpense[]
  tripSettlements      TripSettlement[]
  driverAdvances       DriverAdvance[]
  chartOfAccounts      ChartOfAccount[]
  journalEntries       JournalEntry[]
  freightInvoices      FreightInvoice[]
  transactions         Transaction[]
  auditLogs            AuditLog[]
  bankAccounts         BankAccount[]
  tdsEntries           TdsEntry[]
  gstReturns           GstReturn[]
  complianceDeadlines  ComplianceDeadline[]
  attendances          Attendance[]
  leaves               Leave[]
  vehicleDocuments     VehicleDocument[]
  maintenanceJobs      MaintenanceJob[]
  fuelEntries          FuelEntry[]
  salaryStructures     SalaryStructure[]
  payrollRuns          PayrollRun[]
  payrollLines         PayrollLine[]
  scheduledReports     ScheduledReport[]
  reportCaches         ReportCache[]
  drivers              Driver[]
  labourExpenses       LabourExpense[]
  labourAttendance     LabourAttendance[]
  driverAssignments    DriverAssignment[]
  employeeTransactions EmployeeTransaction[]
  leaveAllocations     LeaveAllocation[]
  accountingSettings   AccountingSetting[]
  palletMasters        PalletMaster[]
  tyres                VehicleTyre[]
  maintenanceSchedules MaintenanceSchedule[]
  chequeBooks          ChequeBook[]
  financialYears       FinancialYear[]
  backupJobs           BackupJob[]
  backupRestoreJobs    BackupRestoreJob[]
  backupSchedules      BackupSchedule[]

  @@map("tenants")
}

model TenantModule {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  moduleKey String   @map("module_key") @db.VarChar(50)
  isEnabled Boolean  @default(true) @map("is_enabled")
  enabledBy String?  @map("enabled_by") @db.Uuid
  enabledAt DateTime @default(now()) @map("enabled_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleKey])
  @@map("tenant_modules")
}

model LicenseKey {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  keyHash     String   @map("key_hash") @db.Text
  plan        String   @db.VarChar(50)
  maxUsers    Int      @map("max_users")
  maxVehicles Int      @map("max_vehicles")
  expiresAt   DateTime @map("expires_at") @db.Timestamptz()
  issuedAt    DateTime @default(now()) @map("issued_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("license_keys")
}

model LicenseRequest {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  planType  String   @map("plan_type") @db.VarChar(50)
  status    String   @default("pending") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@map("license_requests")
}

model SupportMessage {
  id            String   @id @default(uuid()) @db.Uuid
  requestId     String   @map("request_id") @db.Uuid
  senderId      String?  @map("sender_id") @db.Uuid
  adminId       String?  @map("admin_id") @db.Uuid
  message       String   @db.Text
  isAction      Boolean  @default(false) @map("is_action")
  type          String?  @db.VarChar(50)
  payload       Json?
  attachmentUrl String?  @map("attachment_url") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  request LicenseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender  User?          @relation(fields: [senderId], references: [id], onDelete: SetNull)
  admin   PlatformAdmin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@map("support_messages")
}

model PlatformAdmin {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.Text
  role         String    @default("super_admin") @db.VarChar(50)
  lastLogin    DateTime? @map("last_login") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  auditLogs       AuditLogPlatform[]
  supportMessages SupportMessage[]

  @@map("platform_admins")
}

model GlobalSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("global_settings")
}

model KycDocument {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  type          String    @db.VarChar(50) // GST, RC, PAN, LICENSE
  url           String    @db.Text
  status        String    @default("pending") @db.VarChar(20) // pending, verified, rejected
  rejectionNote String?   @map("rejection_note") @db.Text
  verifiedAt    DateTime? @map("verified_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

model PlatformInvoice {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  invoiceNumber String    @unique @map("invoice_number") @db.VarChar(50)
  amount        Decimal   @db.Decimal(12, 2)
  status        String    @default("unpaid") @db.VarChar(20) // unpaid, paid, void
  dueDate       DateTime  @map("due_date") @db.Timestamptz()
  paidAt        DateTime? @map("paid_at") @db.Timestamptz()
  items         Json // Array of items: { description: string, amount: number }
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("platform_invoices")
}

model RevenueSnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  mrr           Decimal  @db.Decimal(12, 2)
  arr           Decimal  @db.Decimal(12, 2)
  activeTenants Int      @map("active_tenants")
  churnRate     Decimal  @map("churn_rate") @db.Decimal(5, 2)
  capturedAt    DateTime @default(now()) @map("captured_at") @db.Timestamptz()

  @@map("revenue_snapshots")
}

model FeatureFlag {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @unique @db.VarChar(100)
  description   String?  @db.Text
  status        String   @default("disabled") @db.VarChar(20) // disabled, beta, ga
  globalEnabled Boolean  @default(false) @map("global_enabled")
  tenantIds     String[] @default([]) @map("tenant_ids") @db.Uuid // Target tenants for beta
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("feature_flags")
}

model PlatformApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String    @db.VarChar(100)
  key        String    @unique @db.VarChar(255)
  status     String    @default("active") @db.VarChar(20)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz()
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("platform_api_keys")
}

model WebhookConfig {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  url       String   @db.Text
  events    String[] @default([])
  status    String   @default("active") @db.VarChar(20)
  secret    String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("webhook_configs")
}

model SupportTicket {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  subject       String   @db.VarChar(255)
  description   String   @db.Text
  category      String   @default("support") @db.VarChar(50) // bug, license, support, billing
  status        String   @default("open") @db.VarChar(50) // open, pending, blocked, solved, closed
  priority      String   @default("medium") @db.VarChar(20) // low, medium, high, urgent
  adminResponse String?  @map("admin_response") @db.Text
  attachments   Json?    @default("[]")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("support_tickets")
}

model TenantUsage {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  metricName  String   @map("metric_name") @db.VarChar(100)
  metricValue Int      @default(0) @map("metric_value")
  recordedAt  DateTime @default(now()) @map("recorded_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_usage")
}

model AuditLogPlatform {
  id             String   @id @default(uuid()) @db.Uuid
  adminId        String?  @map("admin_id") @db.Uuid
  action         String   @db.VarChar(100)
  targetTenantId String?  @map("target_tenant_id") @db.Uuid
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  admin PlatformAdmin? @relation(fields: [adminId], references: [id])

  @@map("audit_log_platform")
}

// ============================================
// TENANT-LEVEL CORE TABLES
// ============================================

model Company {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  name         String  @db.VarChar(255)
  gstin        String? @db.VarChar(15)
  pan          String? @db.VarChar(10)
  address      String? @db.Text
  city         String? @db.VarChar(100)
  state        String? @db.VarChar(100)
  stateCode    String? @map("state_code") @db.VarChar(5)
  pincode      String? @db.VarChar(10)
  phone        String? @db.VarChar(20)
  email        String? @db.VarChar(255)
  logoUrl      String? @map("logo_url") @db.Text
  signatureUrl String? @map("signature_url") @db.Text
  printHeader  String? @map("print_header") @db.Text
  printFooter  String? @map("print_footer") @db.Text
  printTerms   String? @map("print_terms") @db.Text

  // Advanced Branding & Financials
  bankName        String? @map("bank_name") @db.VarChar(255)
  accountNo       String? @map("account_no") @db.VarChar(50)
  ifscCode        String? @map("ifsc_code") @db.VarChar(20)
  branchName      String? @map("branch_name") @db.VarChar(255)
  primaryColor    String? @default("#3b82f6") @map("primary_color") @db.VarChar(7)
  whatsappNo      String? @map("whatsapp_no") @db.VarChar(20)
  enableQrCode    Boolean @default(false) @map("enable_qr_code")
  enableWatermark Boolean @default(false) @map("enable_watermark")
  watermarkText   String? @default("ORIGINAL") @map("watermark_text") @db.VarChar(50)

  fiscalYearStart            Int      @default(4) @map("fiscal_year_start")
  isActive                   Boolean  @default(true) @map("is_active")
  registrationCertificateUrl String?  @map("registration_certificate_url") @db.Text
  gstCertificateUrl          String?  @map("gst_certificate_url") @db.Text
  panCardUrl                 String?  @map("pan_card_url") @db.Text
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branches             Branch[]
  users                User[]
  dealers              Dealer[]
  consignors           Consignor[]
  consignees           Consignee[]
  vehicles             Vehicle[]
  labours              Labour[]
  productCategories    ProductCategory[]
  productUnits         ProductUnit[]
  products             Product[]
  employees            Employee[]
  orders               Order[]
  pallets              OrderPallet[]
  trips                Trip[]
  chartOfAccounts      ChartOfAccount[]
  journalEntries       JournalEntry[]
  freightInvoices      FreightInvoice[]
  transactions         Transaction[]
  payrollRuns          PayrollRun[]
  driverAdvances       DriverAdvance[]
  tdsEntries           TdsEntry[]
  labourExpenses       LabourExpense[]
  labourAttendance     LabourAttendance[]
  employeeTransactions EmployeeTransaction[]

  orderDetails           OrderDetail[]
  accountingSettings     AccountingSetting[]
  palletDetails          PalletDetail[]
  palletConsigneeDetails PalletConsigneeDetail[]
  lrStatusLogs           LrStatusLog[]
  podRecords             PodRecord[]
  tripExpenses           TripExpense[]
  tripSettlements        TripSettlement[]
  journalLines           JournalLine[]
  salaryStructures       SalaryStructure[]
  payrollLines           PayrollLine[]
  vehicleDocuments       VehicleDocument[]
  auditLogs              AuditLog[]
  bankAccounts           BankAccount[]
  maintenanceJobs        MaintenanceJob[]
  fuelEntries            FuelEntry[]
  gstReturns             GstReturn[]
  complianceDeadlines    ComplianceDeadline[]
  attendances            Attendance[]
  leaves                 Leave[]
  scheduledReports       ScheduledReport[]
  reportCaches           ReportCache[]
  drivers                Driver[]
  driverAssignments      DriverAssignment[]
  leaveAllocations       LeaveAllocation[]
  palletMasters          PalletMaster[]
  tyres                  VehicleTyre[]
  maintenanceSchedules   MaintenanceSchedule[]
  chequeBooks            ChequeBook[]
  financialYears         FinancialYear[]
  backupJobs             BackupJob[]
  backupRestoreJobs      BackupRestoreJob[]
  backupSchedules        BackupSchedule[]

  @@index([tenantId])
  @@map("companies")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String   @db.VarChar(255)
  address   String?  @db.Text
  stateCode String?  @map("state_code") @db.VarChar(5)
  managerId String?  @map("manager_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users          User[]
  journalEntries JournalEntry[]
  employees      Employee[]

  @@index([companyId])
  @@map("branches")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  companyId         String?   @map("company_id") @db.Uuid
  authUid           String?   @unique @map("auth_uid") @db.VarChar(255)
  passwordHash      String?   @map("password_hash") @db.Text
  name              String    @db.VarChar(255)
  email             String?   @unique @db.VarChar(255)
  phone             String?   @unique @db.VarChar(20)
  role              String    @default("staff") @db.VarChar(50)
  branchId          String?   @map("branch_id") @db.Uuid
  isActive          Boolean   @default(true) @map("is_active")
  isEmailVerified   Boolean   @default(false) @map("is_email_verified")
  verificationToken String?   @map("verification_token") @db.VarChar(255)
  otpCode           String?   @map("otp_code") @db.VarChar(10)
  otpExpires        DateTime? @map("otp_expires") @db.Timestamptz()
  avatarUrl         String?   @map("avatar_url") @db.Text
  permissions       Json?     @default("{}") @map("permissions")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])
  branch  Branch?  @relation(fields: [branchId], references: [id])

  employees              Employee[]
  auditLogs              AuditLog[]
  licenseRequests        LicenseRequest[]
  supportMessages        SupportMessage[]
  supportTickets         SupportTicket[]
  notifications          SystemNotification[]
  otpVerifications       OtpVerification[]
  backupJobsCreated      BackupJob[]        @relation("BackupCreator")
  restoreJobsRequested   BackupRestoreJob[] @relation("RestoreRequester")

  @@index([tenantId])
  @@index([companyId])
  @@index([authUid])
  @@map("users")
}

// ============================================
// MASTER DATA TABLES
// ============================================

model Dealer {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  companyId    String  @map("company_id") @db.Uuid
  name         String  @db.VarChar(255)
  code         String? @db.VarChar(50)
  shortName    String? @map("short_name") @db.VarChar(100)
  personName   String? @map("person_name") @db.VarChar(255)
  address      String? @db.Text
  pincode      String? @db.VarChar(10)
  area         String? @db.VarChar(100)
  phone        String? @db.VarChar(20)
  email        String? @db.VarChar(255)
  pan          String? @db.VarChar(10)
  gstin        String? @db.VarChar(15)
  serviceTaxNo String? @map("service_tax_no") @db.VarChar(50)
  dealerType   String? @map("dealer_type") @db.VarChar(50)
  isPalletReturn Boolean @default(false) @map("is_pallet_return")

  // Bank Details
  bankName   String? @map("bank_name") @db.VarChar(255)
  accountNo  String? @map("account_no") @db.VarChar(50)
  ifscCode   String? @map("ifsc_code") @db.VarChar(20)
  branchName String? @map("branch_name") @db.VarChar(255)

  // Financials & TDS
  tdsRate    Float   @default(0) @map("tds_rate")
  tdsSection String? @map("tds_section") @db.VarChar(50)

  // Logistics Profile
  fleetSize     Int     @default(0) @map("fleet_size")
  primaryRoutes String? @map("primary_routes") @db.Text

  // Documents
  gstUrl       String? @map("gst_url") @db.Text
  panUrl       String? @map("pan_url") @db.Text
  bankProofUrl String? @map("bank_proof_url") @db.Text

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders  Order[]
  pallets OrderPallet[]
  consignees Consignee[]

  @@index([tenantId])
  @@index([companyId, name])
  @@index([companyId, gstin])
  @@map("dealers")
}

model Consignor {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  companyId   String  @map("company_id") @db.Uuid
  name        String  @db.VarChar(255)
  companyName String? @map("company_name") @db.VarChar(255)
  address     String? @db.Text
  email       String? @db.VarChar(255)
  phone       String? @db.VarChar(20)
  gstin       String? @db.VarChar(15)
  pan         String? @db.VarChar(10)

  // Credit & Financials
  creditLimit Float @default(0) @map("credit_limit")
  creditDays  Int   @default(0) @map("credit_days")

  // MSME & Compliance
  isMsme    Boolean @default(false) @map("is_msme")
  msmeRegNo String? @map("msme_reg_no") @db.VarChar(50)

  // Documents
  imageUrl String? @map("image_url") @db.Text
  gstUrl   String? @map("gst_url") @db.Text
  panUrl   String? @map("pan_url") @db.Text
  msmeUrl  String? @map("msme_url") @db.Text

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId, name])
  @@map("consignors")
}

model Consignee {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  companyId   String  @map("company_id") @db.Uuid
  name        String  @db.VarChar(255)
  companyName String? @map("company_name") @db.VarChar(255)
  address     String? @db.Text
  email       String? @db.VarChar(255)
  phone       String? @db.VarChar(20)
  gstin       String? @db.VarChar(15)
  pan         String? @db.VarChar(10)

  // Credit & Financials
  creditLimit Float @default(0) @map("credit_limit")
  creditDays  Int   @default(0) @map("credit_days")

  // Logistics Preferences
  unloadingHours String? @map("unloading_hours") @db.VarChar(100)
  restrictions   String? @db.Text

  // Documents
  imageUrl String? @map("image_url") @db.Text
  gstUrl   String? @map("gst_url") @db.Text
