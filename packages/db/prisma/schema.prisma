// ============================================
// TRIP TABLES
// ============================================

model Trip {
  id                 String    @id @default(uuid()) @db.Uuid
  companyId          String    @map("company_id") @db.Uuid
  vehicleId          String    @map("vehicle_id") @db.Uuid
  driverId           String?   @map("driver_id") @db.Uuid
  coDriverId         String?   @map("co_driver_id") @db.Uuid
  fromLocation       String?   @map("from_location") @db.VarChar(255)
  toLocation         String?   @map("to_location") @db.VarChar(255)
  departureAt        DateTime? @map("departure_at") @db.Timestamptz()
  expectedDeliveryAt DateTime? @map("expected_delivery_at") @db.Timestamptz()
  status             String    @default("planned") @db.VarChar(20)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id])
  driver         Driver?         @relation("TripDriver", fields: [driverId], references: [id])
  coDriver       Driver?         @relation("TripCoDriver", fields: [coDriverId], references: [id])
  tripOrders     TripOrder[]
  tripExpenses   TripExpense[]
  tripSettlement TripSettlement?
  driverAdvances DriverAdvance[]

  @@index([companyId])
  @@map("trips")
}

model TripOrder {
  id      String @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  tripId  String @map("trip_id") @db.Uuid
  orderId String @map("order_id") @db.Uuid

  trip  Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([tripId, orderId])
  @@map("trip_orders")
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model TripExpense {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  tripId      String   @map("trip_id") @db.Uuid
  type        String   @db.VarChar(50) // toll, fuel, rto, maintenance, food, other
  amount      Int      @default(0) // paise
  description String?  @db.Text
  receiptUrl  String?  @map("receipt_url") @db.Text
  location    String?  @db.VarChar(255)
  recordedAt  DateTime @default(now()) @map("recorded_at") @db.Timestamptz()

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("trip_expenses")
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model TripSettlement {
  id            String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  tripId        String   @unique @map("trip_id") @db.Uuid
  advanceAmount Int      @default(0) @map("advance_amount") // paise
  totalExpenses Int      @default(0) @map("total_expenses") // paise
  balance       Int      @default(0) // paise
  settledBy     String?  @map("settled_by") @db.Uuid
  settledAt     DateTime @default(now()) @map("settled_at") @db.Timestamptz()

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("trip_settlements")
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ============================================
// ACCOUNTING TABLES
// ============================================

model ChartOfAccount {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  code      String   @db.VarChar(50)
  name      String   @db.VarChar(255)
  type      String   @db.VarChar(50) // asset, liability, equity, revenue, expense
  parentId  String?  @map("parent_id") @db.Uuid
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent        ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      ChartOfAccount[] @relation("AccountHierarchy")
  journalLines  JournalLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  branchId    String?  @map("branch_id") @db.Uuid
  voucherType String   @map("voucher_type") @db.VarChar(50) // receipt, payment, contra, journal, sales, purchase
  voucherNo   String   @map("voucher_no") @db.VarChar(50)
  date        DateTime @db.Date
  narration   String?  @db.Text
  refId       String?  @map("ref_id") @db.Uuid
  refType     String?  @map("ref_type") @db.VarChar(50)
  postedBy    String?  @map("posted_by") @db.Uuid
  isPosted    Boolean  @default(true) @map("is_posted")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch  Branch?       @relation(fields: [branchId], references: [id])
  lines   JournalLine[]

  @@unique([companyId, voucherType, voucherNo])
  @@index([companyId, date])
  @@map("journal_entries")
}

model JournalLine {
  id            String  @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  entryId       String  @map("entry_id") @db.Uuid
  accountId     String  @map("account_id") @db.Uuid
  debit         Int     @default(0) // paise
  credit        Int     @default(0) // paise
  costCentreId  String? @map("cost_centre_id") @db.Uuid
