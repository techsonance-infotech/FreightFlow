// ============================================
// FreightFlow Pro — Prisma Schema
// Multi-Tenant SaaS Transport Management
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// PLATFORM-LEVEL TABLES (Super Admin)
// ============================================

model Tenant {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @db.VarChar(255)
  slug             String   @unique @db.VarChar(100)
  plan             String   @default("starter") @db.VarChar(50)
  status           String   @default("active") @db.VarChar(20)
  licenseKey       String?  @map("license_key") @db.Text
  licenseExpiresAt DateTime? @map("license_expires_at") @db.Timestamptz()
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  companies     Company[]
  users         User[]
  modules       TenantModule[]
  licenseKeys   LicenseKey[]
  usageRecords  TenantUsage[]

  dealers       Dealer[]
  consignors    Consignor[]
  consignees    Consignee[]
  vehicles      Vehicle[]
  labours       Labour[]
  employees     Employee[]
  products      Product[]
  orders        Order[]
  pallets       OrderPallet[]
  trips         Trip[]
  tripExpenses  TripExpense[]
  tripSettlements TripSettlement[]
  driverAdvances DriverAdvance[]
  chartOfAccounts ChartOfAccount[]
  journalEntries  JournalEntry[]
  freightInvoices FreightInvoice[]
  transactions    Transaction[]
  auditLogs       AuditLog[]
  bankAccounts    BankAccount[]
  tdsEntries      TdsEntry[]
  gstReturns      GstReturn[]
  complianceDeadlines ComplianceDeadline[]
  attendances      Attendance[]
  leaves           Leave[]
  vehicleDocuments VehicleDocument[]
  maintenanceJobs  MaintenanceJob[]
  fuelEntries      FuelEntry[]
  salaryStructures SalaryStructure[]
  payrollRuns      PayrollRun[]
  payrollLines     PayrollLine[]
  scheduledReports ScheduledReport[]
  reportCaches     ReportCache[]
  drivers          Driver[]

  @@map("tenants")
}

model TenantModule {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  moduleKey String   @map("module_key") @db.VarChar(50)
  isEnabled Boolean  @default(true) @map("is_enabled")
  enabledBy String?  @map("enabled_by") @db.Uuid
  enabledAt DateTime @default(now()) @map("enabled_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleKey])
  @@map("tenant_modules")
}

model LicenseKey {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  keyHash     String   @map("key_hash") @db.Text
  plan        String   @db.VarChar(50)
  maxUsers    Int      @map("max_users")
  maxVehicles Int      @map("max_vehicles")
  expiresAt   DateTime @map("expires_at") @db.Timestamptz()
  issuedAt    DateTime @default(now()) @map("issued_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("license_keys")
}

model PlatformAdmin {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.Text
  role         String    @default("super_admin") @db.VarChar(50)
  lastLogin    DateTime? @map("last_login") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  auditLogs AuditLogPlatform[]

  @@map("platform_admins")
}

model TenantUsage {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  metricName  String   @map("metric_name") @db.VarChar(100)
  metricValue Int      @default(0) @map("metric_value")
  recordedAt  DateTime @default(now()) @map("recorded_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_usage")
}

model AuditLogPlatform {
  id             String   @id @default(uuid()) @db.Uuid
  adminId        String?  @map("admin_id") @db.Uuid
  action         String   @db.VarChar(100)
  targetTenantId String?  @map("target_tenant_id") @db.Uuid
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  admin PlatformAdmin? @relation(fields: [adminId], references: [id])

  @@map("audit_log_platform")
}

// ============================================
// TENANT-LEVEL CORE TABLES
// ============================================

model Company {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  name            String   @db.VarChar(255)
  gstin           String?  @db.VarChar(15)
  pan             String?  @db.VarChar(10)
  address         String?  @db.Text
  city            String?  @db.VarChar(100)
  state           String?  @db.VarChar(100)
  stateCode       String?  @map("state_code") @db.VarChar(5)
  pincode         String?  @db.VarChar(10)
  phone           String?  @db.VarChar(20)
  email           String?  @db.VarChar(255)
  logoUrl         String?  @map("logo_url") @db.Text
  fiscalYearStart Int      @default(4) @map("fiscal_year_start")
  isActive        Boolean  @default(true) @map("is_active")
  registrationCertificateUrl String? @map("registration_certificate_url") @db.Text
  gstCertificateUrl          String? @map("gst_certificate_url") @db.Text
  panCardUrl                 String? @map("pan_card_url") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branches  Branch[]
  users     User[]
  dealers   Dealer[]
  consignors Consignor[]
  consignees Consignee[]
  vehicles  Vehicle[]
  labours   Labour[]
  employees Employee[]
  products  Product[]
  orders    Order[]
  pallets   OrderPallet[]
  trips     Trip[]
  chartOfAccounts ChartOfAccount[]
  journalEntries  JournalEntry[]
  freightInvoices FreightInvoice[]
  transactions    Transaction[]
  payrollRuns     PayrollRun[]
  driverAdvances  DriverAdvance[]
  tdsEntries      TdsEntry[]

  
  orderDetails OrderDetail[]
  palletDetails PalletDetail[]
  palletConsigneeDetails PalletConsigneeDetail[]
  lrStatusLogs LrStatusLog[]
  podRecords PodRecord[]
  tripExpenses TripExpense[]
  tripSettlements TripSettlement[]
  journalLines JournalLine[]
  salaryStructures SalaryStructure[]
  payrollLines PayrollLine[]
  vehicleDocuments VehicleDocument[]
  auditLogs AuditLog[]
  bankAccounts BankAccount[]
  maintenanceJobs MaintenanceJob[]
  fuelEntries FuelEntry[]
  gstReturns GstReturn[]
  complianceDeadlines ComplianceDeadline[]
  attendances Attendance[]
  leaves Leave[]
  scheduledReports ScheduledReport[]
  reportCaches     ReportCache[]
  drivers          Driver[]

  @@index([tenantId])
  @@map("companies")
}

model Branch {
  id        String  @id @default(uuid()) @db.Uuid
  companyId String  @map("company_id") @db.Uuid
  name      String  @db.VarChar(255)
  address   String? @db.Text
  stateCode String? @map("state_code") @db.VarChar(5)
  managerId String? @map("manager_id") @db.Uuid
  isActive  Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  company        Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users          User[]
  journalEntries JournalEntry[]
  employees      Employee[]

  @@index([companyId])
  @@map("branches")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  companyId       String?  @map("company_id") @db.Uuid
  authUid         String?  @unique @map("auth_uid") @db.VarChar(255)
  passwordHash    String?  @map("password_hash") @db.Text
  name            String   @db.VarChar(255)
  email           String?  @unique @db.VarChar(255)
  phone           String?  @unique @db.VarChar(20)
  role            String   @default("staff") @db.VarChar(50)
  branchId        String?  @map("branch_id") @db.Uuid
  isActive        Boolean  @default(true) @map("is_active")
  isEmailVerified Boolean  @default(false) @map("is_email_verified")
  verificationToken String? @map("verification_token") @db.VarChar(255)
  otpCode         String?  @map("otp_code") @db.VarChar(10)
  otpExpires      DateTime? @map("otp_expires") @db.Timestamptz()
  avatarUrl       String?  @map("avatar_url") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])
  branch  Branch?  @relation(fields: [branchId], references: [id])

  @@index([tenantId])
  @@index([companyId])
  @@index([authUid])
  @@map("users")
}

// ============================================
// MASTER DATA TABLES
// ============================================

model Dealer {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  name         String   @db.VarChar(255)
  shortName    String?  @map("short_name") @db.VarChar(100)
  personName   String?  @map("person_name") @db.VarChar(255)
  address      String?  @db.Text
  pincode      String?  @db.VarChar(10)
  area         String?  @db.VarChar(100)
  phone        String?  @db.VarChar(20)
  email        String?  @db.VarChar(255)
  pan          String?  @db.VarChar(10)
  gstin        String?  @db.VarChar(15)
  serviceTaxNo String?  @map("service_tax_no") @db.VarChar(50)
  dealerType   String?  @map("dealer_type") @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders  Order[]
  pallets OrderPallet[]

  @@index([tenantId])
  @@index([companyId, name])
  @@index([companyId, gstin])
  @@map("dealers")
}

model Consignor {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String   @db.VarChar(255)
  companyName String?  @map("company_name") @db.VarChar(255)
  address     String?  @db.Text
  email       String?  @db.VarChar(255)
  gstin       String?  @db.VarChar(15)
  phone       String?  @db.VarChar(20)
  imageUrl    String?  @map("image_url") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId, name])
  @@map("consignors")
}

model Consignee {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String   @db.VarChar(255)
  companyName String?  @map("company_name") @db.VarChar(255)
  address     String?  @db.Text
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(20)
  gstin       String?  @db.VarChar(15)
  pan         String?  @db.VarChar(10)
  imageUrl    String?  @map("image_url") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@index([tenantId])
  @@index([companyId, name])
  @@map("consignees")
}

model Vehicle {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  regNo      String   @map("reg_no") @db.VarChar(20)
  make       String?  @db.VarChar(100)
  model      String?  @db.VarChar(100)
  type       String?  @db.VarChar(50)
  ownership  String   @default("own") @db.VarChar(20)
  chassisNo  String?  @map("chassis_no") @db.VarChar(50)
  engineNo   String?  @map("engine_no") @db.VarChar(50)
  odometer   Int      @default(0)
  status     String   @default("active") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz()

  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders           Order[]
  pallets          OrderPallet[]
  trips            Trip[]
  vehicleDocuments VehicleDocument[]
  maintenanceJobs  MaintenanceJob[]
  fuelEntries      FuelEntry[]

  @@unique([companyId, regNo])
  @@index([tenantId])
  @@index([companyId, status])
  @@map("vehicles")
}

model Labour {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String   @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  address   String?  @db.Text
  salary    Int      @default(0) // stored in paise
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@map("labours")
}

model Employee {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  empCode         String?   @map("emp_code") @db.VarChar(50)
  name            String    @db.VarChar(255)
  phone           String?   @db.VarChar(20)
  email           String?   @db.VarChar(255)
  address         String?   @db.Text
  designation     String?   @db.VarChar(100)
  branchId        String?   @map("branch_id") @db.Uuid
  joiningDate     DateTime? @map("joining_date") @db.Date
  status          String    @default("active") @db.VarChar(20) // active, inactive, terminated
  bankAccount     String?   @map("bank_account") @db.Text // encrypted
  pan             String?   @db.VarChar(10)
  aadharEncrypted String?   @map("aadhar_encrypted") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?          @relation(fields: [branchId], references: [id])
  driver          Driver?
  salaryStructure SalaryStructure?
  payrollLines    PayrollLine[]
  attendances     Attendance[]
  leaves          Leave[]

  @@index([tenantId])
  @@index([companyId, status])
  @@map("employees")
}

model Attendance {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  companyId  String    @map("company_id") @db.Uuid
  employeeId String    @map("employee_id") @db.Uuid
  date       DateTime  @db.Date
  status     String    @db.VarChar(10) // present, absent, half_day, leave, holiday
  checkIn    DateTime? @map("check_in") @db.Timestamptz()
  checkOut   DateTime? @map("check_out") @db.Timestamptz()
  notes      String?   @db.Text
  markedBy   String?   @map("marked_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([companyId, date])
  @@map("attendance")
}

model Leave {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  leaveType   String    @map("leave_type") @db.VarChar(20) // casual, sick, earned, unpaid
  fromDate    DateTime  @map("from_date") @db.Date
  toDate      DateTime  @map("to_date") @db.Date
  days        Int
  reason      String?   @db.Text
  status      String    @default("pending") @db.VarChar(20) // pending, approved, rejected
  approvedBy  String?   @map("approved_by") @db.Uuid
  approvedAt  DateTime? @map("approved_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@map("leaves")
}

model Driver {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  employeeId    String   @unique @map("employee_id") @db.Uuid
  dlNumber      String?  @map("dl_number") @db.VarChar(50)
  dlExpiry      DateTime? @map("dl_expiry") @db.Date
  dlCategory    String?  @map("dl_category") @db.VarChar(20)
  badgeNo       String?  @map("badge_no") @db.VarChar(50)
  isVendorDriver Boolean @default(false) @map("is_vendor_driver")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tripsAsDriver   Trip[]   @relation("TripDriver")
  tripsAsCoDriver Trip[]   @relation("TripCoDriver")
  driverAdvances  DriverAdvance[]

  @@index([companyId])
  @@map("drivers")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  name           String   @db.VarChar(255)
  hsnCode        String?  @map("hsn_code") @db.VarChar(20)
  defaultPacking String?  @map("default_packing") @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@map("products")
}

// ============================================
// LR / ORDER TABLES
// ============================================

model Order {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  lrNo          Int      @map("lr_no")
  gstBillNo     String?  @map("gst_bill_no") @db.VarChar(50)
  dealerId      String?  @map("dealer_id") @db.Uuid
  consigneeId   String?  @map("consignee_id") @db.Uuid
  ewayBillNo    String?  @map("eway_bill_no") @db.VarChar(20)
  vehicleId     String?  @map("vehicle_id") @db.Uuid
  date          DateTime @db.Date
  fromLocation  String?  @map("from_location") @db.VarChar(255)
  toLocation    String?  @map("to_location") @db.VarChar(255)
  freight       Int      @default(0) // paise
  hamali        Int      @default(0) // paise
  rateOn        String   @default("weight") @map("rate_on") @db.VarChar(20)
  rate          Int      @default(0) // paise
  cgstPct       Decimal  @default(0) @map("cgst_pct") @db.Decimal(5, 2)
  sgstPct       Decimal  @default(0) @map("sgst_pct") @db.Decimal(5, 2)
  totalWeight   Decimal  @default(0) @map("total_weight") @db.Decimal(10, 2)
  totalBoxes    Int      @default(0) @map("total_boxes")
  subtotal      Int      @default(0) // paise
  cgstAmount    Int      @default(0) @map("cgst_amount") // paise
  sgstAmount    Int      @default(0) @map("sgst_amount") // paise
  totalAmount   Int      @default(0) @map("total_amount") // paise
  status        String   @default("created") @db.VarChar(20)
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealer     Dealer?    @relation(fields: [dealerId], references: [id])
  consignee  Consignee? @relation(fields: [consigneeId], references: [id])
  vehicle    Vehicle?   @relation(fields: [vehicleId], references: [id])
