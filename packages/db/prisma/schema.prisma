  @@map("journal_lines")
}

model FreightInvoice {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  invoiceNo   String   @unique @map("invoice_no") @db.VarChar(50)
  date        DateTime @db.Date
  customerId  String   @map("customer_id") @db.Uuid // Linked to Dealer/Customer
  subtotal    Int      @map("subtotal") // paise
  cgst        Int      @default(0) @map("cgst") // paise
  sgst        Int      @default(0) @map("sgst") // paise
  igst        Int      @default(0) @map("igst") // paise
  totalAmount Int      @map("total_amount") // paise
  status      String   @default("draft") @db.VarChar(20) // draft, sent, paid, partial, overdue
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
  orders Order[]
  eInvoiceLogs EInvoiceLog[]

  @@index([tenantId])
  @@index([companyId, date])
  @@map("freight_invoices")
}

model Transaction {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  date        DateTime @db.Date
  amount      Int      @map("amount") // paise
  type        String   @db.VarChar(20) // receipt, payment
  mode        String   @db.VarChar(20) // cash, bank, neft, etc.
  referenceNo String?  @map("reference_no") @db.VarChar(100)
  partyId     String   @map("party_id") @db.Uuid
  accountId   String   @map("account_id") @db.Uuid
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([tenantId])
  @@index([companyId])
  @@map("accounting_transactions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(50) // create, update, delete
  entityType String   @map("entity_type") @db.VarChar(50) // JournalEntry, BankAccount, etc.
  entityId   String   @map("entity_id") @db.Uuid
  changes    Json     @map("changes") // JSON detailing before/after
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  company    Company  @relation(fields: [companyId], references: [id])

  @@index([tenantId])
  @@index([companyId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model BankAccount {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  companyId              String   @map("company_id") @db.Uuid
  bankName               String   @map("bank_name") @db.VarChar(100)
  accountName            String   @map("account_name") @db.VarChar(100)
  encryptedAccountNumber String   @map("encrypted_account_number") @db.Text
  ifscCode               String   @map("ifsc_code") @db.VarChar(20)
  branchName             String?  @map("branch_name") @db.VarChar(100)
  chartOfAccountId       String   @map("chart_of_account_id") @db.Uuid // Linked to GL
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  company        Company        @relation(fields: [companyId], references: [id])
  chartOfAccount ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])

  @@index([tenantId])
  @@index([companyId])
  @@map("bank_accounts")
}

// --- PHASE 6: GST & TDS COMPLIANCE ---

model GstReturn {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  returnType  String   @map("return_type") @db.VarChar(20) // GSTR1, GSTR3B
  period      String   @db.VarChar(20) // e.g., 2026-04
  arn         String?  @db.VarChar(100)
  status      String   @default("draft") @db.VarChar(20) // draft, filed
  filedAt     DateTime? @map("filed_at") @db.Timestamptz()
  jsonPayload Json?    @map("json_payload")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([tenantId])
  @@index([companyId])
  @@map("gst_returns")
}

model EInvoiceLog {
  id             String   @id @default(uuid()) @db.Uuid
  invoiceId      String   @map("invoice_id") @db.Uuid
  irn            String?  @db.VarChar(100)
  ackNo          String?  @map("ack_no") @db.VarChar(100)
  ackDate        DateTime? @map("ack_date") @db.Timestamptz()
  signedInvoice  String?  @map("signed_invoice") @db.Text
  qrCode         String?  @map("qr_code") @db.Text
  status         String   @default("pending") @db.VarChar(20) // pending, generated, cancelled, failed
  errorMessage   String?  @map("error_message") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  invoice FreightInvoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("einvoice_logs")
}

model ComplianceDeadline {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  deadlineType String   @map("deadline_type") @db.VarChar(50) // GSTR1, GSTR3B, TDS
  description  String   @db.Text
  dueDate      DateTime @map("due_date") @db.Date
  status       String   @default("pending") @db.VarChar(20) // pending, completed
  alertSent    Boolean  @default(false) @map("alert_sent")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([tenantId])
  @@index([companyId])
  @@map("compliance_deadlines")
}

model ScheduledReport {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  reportType      String   @map("report_type") @db.VarChar(50)
  schedule        String   @db.VarChar(20) // daily|weekly|monthly
  parameters      Json?    @map("parameters")
  recipientEmails String[] @map("recipient_emails")
  lastRunAt       DateTime? @map("last_run_at") @db.Timestamptz()
  nextRunAt       DateTime? @map("next_run_at") @db.Timestamptz()
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@map("scheduled_reports")
}

model ReportCache {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  reportType     String   @map("report_type") @db.VarChar(50)
  parametersHash String   @map("parameters_hash") @db.VarChar(64)
  data           Json     @map("data")
  generatedAt    DateTime @default(now()) @map("generated_at") @db.Timestamptz()
  expiresAt      DateTime @map("expires_at") @db.Timestamptz()

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, reportType, parametersHash])
  @@map("report_caches")
}
