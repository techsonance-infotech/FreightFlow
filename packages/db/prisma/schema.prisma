// --- PHASE 4: TRIP MANAGEMENT ---

model Trip {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  companyId          String    @map("company_id") @db.Uuid
  vehicleId          String    @map("vehicle_id") @db.Uuid
  driverId           String    @map("driver_id") @db.Uuid
  coDriverId         String?   @map("co_driver_id") @db.Uuid
  fromLocation       String    @map("from_location") @db.VarChar(255)
  toLocation         String    @map("to_location") @db.VarChar(255)
  departureAt        DateTime? @map("departure_at") @db.Timestamptz()
  expectedDeliveryAt DateTime? @map("expected_delivery_at") @db.Timestamptz()
  actualDeliveryAt   DateTime? @map("actual_delivery_at") @db.Timestamptz()
  advanceAmount      Int       @default(0) @map("advance_amount") // paise
  status             String    @default("created") @db.VarChar(20) // created, loaded, in_transit, delivered, settled
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz()

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id])
  driver   Driver   @relation("TripDriver", fields: [driverId], references: [id])
  coDriver Driver?  @relation("TripCoDriver", fields: [coDriverId], references: [id])
  orders   Order[]
  expenses TripExpense[]
  advances DriverAdvance[]
  settlement TripSettlement?

  @@index([tenantId])
  @@index([companyId, status])
  @@index([vehicleId])
  @@index([driverId])
  @@map("trips")
}

model TripExpense {
