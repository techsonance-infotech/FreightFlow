# ========================================
# FreightFlow Pro — Environment Variables
# ========================================
# Copy this file to .env.local and fill in your values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# --- Security ---
JWT_SECRET=your-32-char-random-string-for-license-signing

# --- AI (Phase 11) ---
# OPENAI_API_KEY=sk-...

# --- Email (Phase 1+) ---
# RESEND_API_KEY=re_...

# --- SMS (Phase 1+) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- Redis / Queue (Phase 1+) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Maps (Phase 4+) ---
# GOOGLE_MAPS_API_KEY=

# --- Payments (Phase 12) ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# --- GST / e-Way Bill (Phase 6) ---
# NIC_EWB_USERNAME=
# NIC_EWB_PASSWORD=

# --- Platform Admin (Seed) ---
PLATFORM_ADMIN_EMAIL=admin@freightflowpro.com
PLATFORM_ADMIN_PASSWORD=changeme123

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000/portal
